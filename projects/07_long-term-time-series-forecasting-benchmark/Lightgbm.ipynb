from pathlib import Path

import matplotlib.pyplot as plt
import pandas as pd
from sklearn.metrics import r2_score


BASE_DIR = Path("outputs")
DATASETS = ["ETTm1", "weather", "electricity"]


def ensure_dir(path: Path) -> None:
    path.mkdir(parents=True, exist_ok=True)


def add_rank_columns(summary: pd.DataFrame) -> pd.DataFrame:
    ranked_frames = []
    for pred_len, group in summary.groupby("pred_len"):
        ranked = group.copy()
        ranked["rank_by_rmse"] = ranked["rmse"].rank(method="min").astype(int)
        ranked["rank_by_mape"] = ranked["mape"].rank(method="min").astype(int)
        ranked_frames.append(ranked.sort_values("rank_by_rmse"))
    return pd.concat(ranked_frames, ignore_index=True)


def build_analysis_table(summary: pd.DataFrame) -> pd.DataFrame:
    rows = []
    note_map = {
        "ETTm1": "Short-term forecasting is strong and the predicted curve follows the true series closely.",
        "weather": "Relative error is stable, making this dataset suitable for percentage-based comparisons.",
        "electricity": "This scenario remains difficult and likely needs dataset-specific tuning.",
    }
    for _, row in summary.iterrows():
        dataset = row["dataset"]
        pred_len = int(row["pred_len"])
        preds = pd.read_csv(BASE_DIR / f"pred_len_{pred_len}" / dataset / "predictions.csv")
        rows.append(
            {
                "dataset": dataset,
                "pred_len": pred_len,
                "rank_by_rmse": int(row["rank_by_rmse"]),
                "rank_by_mape": int(row["rank_by_mape"]),
                "mae": round(float(row["mae"]), 4),
                "rmse": round(float(row["rmse"]), 4),
                "mape_percent": round(float(row["mape"]), 4),
                "r2": round(float(r2_score(preds["actual"], preds["predicted"])), 4),
                "test_samples": int(row["test_samples"]),
                "actual_mean": round(float(preds["actual"].mean()), 4),
                "actual_std": round(float(preds["actual"].std()), 4),
                "avg_abs_error": round(float(preds["abs_error"].mean()), 4),
                "presentation_note": note_map.get(dataset, ""),
            }
        )
    return pd.DataFrame(rows).sort_values(["pred_len", "rank_by_rmse", "dataset"])


def plot_dataset(dataset: str, pred_len: int, out_dir: Path) -> None:
    df = pd.read_csv(BASE_DIR / f"pred_len_{pred_len}" / dataset / "predictions.csv")
    df["date"] = pd.to_datetime(df["date"])
    sample_size = min(len(df), 300)
    plot_df = df.tail(sample_size).copy()

    fig, ax = plt.subplots(figsize=(12, 5))
    ax.plot(plot_df["date"], plot_df["actual"], label="Actual", linewidth=2)
    ax.plot(plot_df["date"], plot_df["predicted"], label="Predicted", linewidth=2)
    ax.set_title(f"{dataset}: Actual vs Predicted (pred_len={pred_len}, last {sample_size} points)")
    ax.set_xlabel("Time")
    ax.set_ylabel("OT")
    ax.grid(True, alpha=0.3)
    ax.legend()
    fig.autofmt_xdate()
    fig.tight_layout()
    fig.savefig(out_dir / f"{dataset}_pred_len_{pred_len}.png", dpi=180)
    plt.close(fig)


def build_markdown(analysis: pd.DataFrame, out_path: Path) -> None:
    lines = [
        "# LSTM Horizon Comparison",
        "",
        "This report compares multiple forecast horizons across datasets.",
        "",
    ]
    for pred_len, group in analysis.groupby("pred_len"):
        lines.append(f"## pred_len = {pred_len}")
        lines.append("")
        lines.append("| Dataset | RMSE Rank | MAPE Rank | MAE | RMSE | MAPE (%) | R2 | Note |")
        lines.append("|---|---:|---:|---:|---:|---:|---:|---|")
        for _, row in group.sort_values("rank_by_rmse").iterrows():
            lines.append(
                f"| {row['dataset']} | {row['rank_by_rmse']} | {row['rank_by_mape']} | "
                f"{row['mae']} | {row['rmse']} | {row['mape_percent']} | {row['r2']} | {row['presentation_note']} |"
            )
        lines.append("")
    out_path.write_text("\n".join(lines), encoding="utf-8")


def main() -> None:
    figures_dir = BASE_DIR / "figures"
    report_dir = BASE_DIR / "report"
    ensure_dir(figures_dir)
    ensure_dir(report_dir)

    summary = pd.read_csv(BASE_DIR / "summary_metrics.csv")
    summary = add_rank_columns(summary)

    for pred_len in sorted(summary["pred_len"].unique()):
        for dataset in DATASETS:
            plot_dataset(dataset, int(pred_len), figures_dir)

    analysis = build_analysis_table(summary)
    analysis.to_csv(report_dir / "analysis_table.csv", index=False, encoding="utf-8-sig")
    build_markdown(analysis, report_dir / "analysis_report.md")

    print(f"Saved figures to: {figures_dir}")
    print(f"Saved analysis table to: {report_dir / 'analysis_table.csv'}")
    print(f"Saved markdown report to: {report_dir / 'analysis_report.md'}")


if __name__ == "__main__":
    main()
